<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Import <%= imp.id %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 2rem;
      color: #1f2937;
      background: #ffffff;
    }
    h1, h2 {
      margin-bottom: 0.5rem;
    }
    p {
      color: #4b5563;
    }
    .top-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }
    a {
      color: #2563eb;
      text-decoration: none;
    }
    .meta, .summary-grid, .panel {
      margin-bottom: 1.5rem;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 1rem;
    }
    .card, .panel {
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      padding: 1rem;
      background: #fff;
    }
    .card strong {
      display: block;
      font-size: 1.4rem;
      color: #111827;
      margin-bottom: 0.25rem;
    }
    .muted {
      color: #6b7280;
    }
    .scroll {
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 0.75rem;
      min-width: 900px;
    }
    th, td {
      border: 1px solid #e5e7eb;
      padding: 0.7rem;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: #f3f4f6;
    }
    td.num, th.num {
      text-align: right;
      white-space: nowrap;
    }
    .issue-badge {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      background: #fef3c7;
      color: #92400e;
      font-size: 0.85rem;
      white-space: nowrap;
    }
    .issue-badge.resolved {
      background: #dcfce7;
      color: #166534;
    }
    .issue-badge.ignored {
      background: #e5e7eb;
      color: #374151;
    }
    .ok-empty {
      color: #6b7280;
      padding: 0.25rem 0 0;
    }
    .issue-actions {
      min-width: 320px;
    }
    .issue-actions form {
      margin-bottom: 0.5rem;
      padding: 0.75rem;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
    }
    .issue-actions label {
      display: block;
      font-size: 0.9rem;
      color: #374151;
      margin-bottom: 0.3rem;
      font-weight: 600;
    }
    .issue-actions input[type="text"],
    .issue-actions select {
      width: 100%;
      padding: 0.55rem 0.65rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      margin-bottom: 0.65rem;
      background: #fff;
    }
    .btn-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .btn, button {
      display: inline-block;
      padding: 0.65rem 0.9rem;
      border-radius: 8px;
      border: 1px solid #d1d5db;
      background: #111827;
      color: #fff;
      text-decoration: none;
      cursor: pointer;
      font-size: 0.92rem;
    }
    .btn.secondary,
    button.secondary {
      background: #fff;
      color: #111827;
    }
    .raw-preview {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: #4b5563;
      white-space: pre-wrap;
      word-break: break-word;
      background: #f9fafb;
      padding: 0.6rem;
      border-radius: 6px;
      border: 1px solid #e5e7eb;
      max-width: 500px;
    }
  </style>
</head>
<body>
  <div class="top-links">
    <a href="/">← Back to dashboard</a>
    <a href="/expenses/new">Add expense</a>
    <a href="/sales/new">Record sale</a>
  </div>

  <h1>Import #<%= imp.id %></h1>
  <div class="meta">
    <p>
      <strong><%= imp.filename %></strong><br />
      Imported: <%= imp.imported_at %><br />
      Parsed rows: <%= imp.row_count %>
    </p>
  </div>

  <div class="summary-grid">
    <div class="card">
      <strong><%= accounts.length %></strong>
      <span>Account snapshots</span>
    </div>
    <div class="card">
      <strong><%= properties.length %></strong>
      <span>Properties with transactions</span>
    </div>
    <div class="card">
      <strong><%= propertyValues.length %></strong>
      <span>Property values</span>
    </div>
    <div class="card">
      <strong><%= issues.filter(function(i) { return (i.status || 'open') === 'open'; }).length %></strong>
      <span>Open issues</span>
    </div>
  </div>

  <div class="panel">
    <h2>Property rollup</h2>
    <% if (properties && properties.length) { %>
      <div class="scroll">
        <table>
          <thead>
            <tr>
              <th>Property</th>
              <th class="num">Transactions</th>
              <th class="num">Income</th>
              <th class="num">Expenses</th>
              <th class="num">Net</th>
            </tr>
          </thead>
          <tbody>
            <% properties.forEach(function(row) { %>
              <tr>
                <td><%= row.property_name || '' %></td>
                <td class="num"><%= row.txn_count ?? '' %></td>
                <td class="num"><%= formatCurrency(row.income_total) %></td>
                <td class="num"><%= formatCurrency(row.expense_total) %></td>
                <td class="num"><%= formatCurrency(row.net_total) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="ok-empty">No property transaction rollup is available for this import.</p>
    <% } %>
  </div>

  <div class="panel">
    <h2>Property values</h2>
    <% if (propertyValues && propertyValues.length) { %>
      <div class="scroll">
        <table>
          <thead>
            <tr>
              <th>Address</th>
              <th class="num">Purchased</th>
              <th class="num">Estimate</th>
              <th>Snapshot date</th>
              <th class="num">Profit/Loss</th>
              <th class="num">Alt estimate</th>
              <th>Alt snapshot</th>
            </tr>
          </thead>
          <tbody>
            <% propertyValues.forEach(function(row) { %>
              <tr>
                <td><%= row.address || '' %></td>
                <td class="num"><%= formatCurrency(row.purchased) %></td>
                <td class="num"><%= formatCurrency(row.estimate) %></td>
                <td><%= row.snapshot_date || '' %></td>
                <td class="num"><%= formatCurrency(row.profit_loss) %></td>
                <td class="num"><%= formatCurrency(row.alt_estimate) %></td>
                <td><%= row.alt_snapshot_date || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="ok-empty">No property valuation rows were imported.</p>
    <% } %>
  </div>

  <div class="panel">
    <h2>Account snapshots</h2>
    <% if (accounts && accounts.length) { %>
      <div class="scroll">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Bank</th>
              <th>Type</th>
              <th>Account</th>
              <th>Routing</th>
              <th class="num">Balance</th>
              <th>Sheet</th>
            </tr>
          </thead>
          <tbody>
            <% accounts.forEach(function(row) { %>
              <tr>
                <td><%= row.snapshot_date || '' %></td>
                <td><%= row.bank || '' %></td>
                <td><%= row.account_type || '' %></td>
                <td><%= row.account_num || '' %></td>
                <td><%= row.routing || '' %></td>
                <td class="num"><%= formatCurrency(row.balance) %></td>
                <td><%= row.source_sheet || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="ok-empty">No account snapshots were imported.</p>
    <% } %>
  </div>

  <div class="panel">
    <h2>Review and repair issues</h2>
    <% if (issues && issues.length) { %>
      <div class="scroll">
        <table>
          <thead>
            <tr>
              <th>Sheet</th>
              <th>Row</th>
              <th>Status</th>
              <th>Type</th>
              <th>Message</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% issues.forEach(function(row) { %>
              <% const status = row.status || 'open'; %>
              <% const payload = row.raw_payload ? JSON.parse(row.raw_payload) : {}; %>
              <% const defaultProperty = (payload['Property '] || payload['Property'] || ''); %>
              <tr>
                <td><%= row.sheet_name || '' %></td>
                <td><%= row.row_number ?? '' %></td>
                <td>
                  <span class="issue-badge <%= status === 'resolved' ? 'resolved' : (status === 'ignored' ? 'ignored' : '') %>">
                    <%= status %>
                  </span>
                </td>
                <td><span class="issue-badge"><%= row.issue_type || '' %></span></td>
                <td>
                  <%= row.message || '' %>
                  <% if (row.resolution_type) { %>
                    <div class="muted" style="margin-top: 0.4rem;">
                      Resolution: <%= row.resolution_type %>
                    </div>
                  <% } %>
                  <div class="raw-preview"><%= JSON.stringify(payload, null, 2) %></div>
                </td>
                <td class="issue-actions">
                  <% if (status === 'open') { %>
                    <% if (row.issue_type === 'invalid_transaction_amount') { %>
                      <form method="POST" action="/imports/<%= imp.id %>/issues/<%= row.id %>/resolve">
                        <label for="corrected_amount_<%= row.id %>">Corrected amount</label>
                        <input
                          id="corrected_amount_<%= row.id %>"
                          name="corrected_amount"
                          type="text"
                          placeholder="Example: 1250.00"
                          required
                        />

                        <label for="mapped_property_amount_<%= row.id %>">Property, optional</label>
                        <select id="mapped_property_amount_<%= row.id %>" name="mapped_property">
                          <option value="">No property</option>
                          <% propertyOptions.forEach(function(option) { %>
                            <option value="<%= option %>" <%= normalizePropertyName ? '' : '' %>><%= option %></option>
                          <% }) %>
                        </select>

                        <div class="btn-row">
                          <button type="submit">Resolve amount</button>
                        </div>
                      </form>
                    <% } %>

                    <% if (row.issue_type === 'unmatched_property_name') { %>
                      <form method="POST" action="/imports/<%= imp.id %>/issues/<%= row.id %>/resolve">
                        <label for="mapped_property_<%= row.id %>">Map property</label>
                        <select id="mapped_property_<%= row.id %>" name="mapped_property" required>
                          <option value="">Select property</option>
                          <% propertyOptions.forEach(function(option) { %>
                            <option
                              value="<%= option %>"
                              <%= option === defaultProperty || option === normalizePropertyName(defaultProperty) ? 'selected' : '' %>>
                              <%= option %>
                            </option>
                          <% }) %>
                        </select>

                        <div class="btn-row">
                          <button type="submit">Resolve property</button>
                        </div>
                      </form>
                    <% } %>

                    <% if (row.issue_type !== 'invalid_transaction_amount' && row.issue_type !== 'unmatched_property_name') { %>
                      <div class="muted" style="margin-bottom: 0.75rem;">
                        No inline repair form is configured yet for this issue type.
                      </div>
                    <% } %>

                    <form method="POST" action="/imports/<%= imp.id %>/issues/<%= row.id %>/ignore">
                      <label for="ignore_reason_<%= row.id %>">Ignore note, optional</label>
                      <input
                        id="ignore_reason_<%= row.id %>"
                        name="reason"
                        type="text"
                        placeholder="Why this issue can be ignored"
                      />
                      <div class="btn-row">
                        <button type="submit" class="secondary">Ignore issue</button>
                      </div>
                    </form>
                  <% } else { %>
                    <div class="muted">
                      This issue has been <%= status %>.
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="ok-empty">No import issues were recorded for this import.</p>
    <% } %>
  </div>
</body>
</html>
